@using PustokAppMvc.Models
@model Book
@{
    ViewData["Title"] = "Create Book";
    var authors = ViewBag.authors as List<Author>;
}

<div class="row">
    <div class="col-lg-12 mb-4">
        <h1>Create Book</h1>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            
            <div class="form-group mb-3">
                <label asp-for="Name" class="form-label">Name</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Description" class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="Price" class="form-label">Price</label>
                        <input asp-for="Price" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="DiscountPercent" class="form-label">Discount Percent</label>
                        <input asp-for="DiscountPercent" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="DiscountPercent" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="Code" class="form-label">Code</label>
                        <input asp-for="Code" class="form-control" type="number" />
                        <span asp-validation-for="Code" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="AuthorId" class="form-label">Author</label>
                <select asp-for="AuthorId" class="form-control" asp-items="@(new SelectList(authors, "Id", "FullName"))">
                    <option value="">Select Author...</option>
                </select>
                <span asp-validation-for="AuthorId" class="text-danger"></span>
            </div>

            <div class="form-check mb-2">
                <input asp-for="InStock" class="form-check-input" />
                <label asp-for="InStock" class="form-check-label">In Stock</label>
            </div>

            <div class="form-check mb-2">
                <input asp-for="IsNew" class="form-check-input" />
                <label asp-for="IsNew" class="form-check-label">Is New</label>
            </div>

            <div class="form-check mb-4">
                <input asp-for="IsFeatured" class="form-check-input" />
                <label asp-for="IsFeatured" class="form-check-label">Is Featured</label>
            </div>

            <div class="form-group mb-3">
                <label class="form-label">Main Image</label>
                <input name="mainImage" class="form-control" type="file" accept="image/*" />
            </div>

            <div class="form-group mb-3">
                <label class="form-label">Hover Image</label>
                <input name="hoverImage" class="form-control" type="file" accept="image/*" />
            </div>

            <div class="form-group mb-4">
                <label class="form-label">Additional Images</label>
                <input name="bookImages" class="form-control" type="file" accept="image/*" multiple />
            </div>

            <button type="submit" class="btn btn-primary">Create</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section scripts {
    <partial name="_ValidationScriptsPartial" />
}
