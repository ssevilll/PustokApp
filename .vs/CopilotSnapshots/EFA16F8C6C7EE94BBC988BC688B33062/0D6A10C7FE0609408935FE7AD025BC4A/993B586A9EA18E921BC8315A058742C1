@using PustokAppMvc.Models
@model List<Book>
@{
    ViewData["Title"] = "Books";
}

<div class="row">
    <div class="col-lg-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Books</h1>
            <a asp-action="Create" class="btn btn-primary">Create New</a>
        </div>
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Image</th>
                    <th>Name</th>
                    <th>Price</th>
                    <th>Discount Percent</th>
                    <th>Author</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>
                                @if(!string.IsNullOrEmpty(item.MainImageUrl))
                                {
                                    <img src="~/image/products/@item.MainImageUrl" style="max-width: 100px;" alt="@item.Name" />
                                }
                                else
                                {
                                    <span class="text-muted">No Image</span>
                                }
                            </td>
                            <td>@item.Name</td>
                            <td>$@item.Price</td>
                            <td>@item.DiscountPercent%</td>
                            <td>@item.Author?.FullName</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                                <a asp-action="ModalDetails" asp-route-id="@item.Id" class="btn btn-info btn-sm">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm deleteBook">Delete</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center">No books found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section scripts {
    <script>
         $('.deleteBook').click(function (e) {
            e.preventDefault();
            Swal.fire({
              title: "Do you want to delete this book?",
              showCancelButton: true,
              confirmButtonText: "Yes, delete it"
            }).then((result) => {
              if (result.isConfirmed)
              {
                var url = $(this).attr('href');
                $.ajax({
                    url: url,
                    type: 'get',
                    success: function (response) {
                        if (response.success) {
                            Swal.fire("Deleted!", response.message, "success").then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire("Error!", response.message, "error");
                        }
                    },
                    error: function () {
                        Swal.fire("Error!", "An error occurred while processing your request.", "error");
                    }
                });
              }
              else if (result.isDenied) Swal.fire("Changes are not saved", "", "info");
            });
        });
    </script>
}