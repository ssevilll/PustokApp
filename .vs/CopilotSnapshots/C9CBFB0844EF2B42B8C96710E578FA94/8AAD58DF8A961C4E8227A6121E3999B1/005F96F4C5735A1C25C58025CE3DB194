@using PustokAppMvc.Models
@model List<Author>
@{
    ViewData["Title"] = "Authors";
}

<div class="row">
    <div class="col-lg-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Authors</h1>
            <a asp-action="Create" class="btn btn-primary">Create New</a>
        </div>
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Full Name</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.FullName</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm details">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm deleteAuthor">Delete</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center">No authors found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="authorModal" tabindex="-1" aria-labelledby="authorModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" id="authorModalContent">
            <!-- Modal content will be loaded here via AJAX -->
        </div>
    </div>
</div>

@section scripts{
<script>
        $('.modalDetails').click(function (e) {
            e.preventDefault();
            var url = $(this).attr('href');
                
            $.get(url, function (data) {
                $('#authorModalContent').html(data);
                $('#authorModal').modal('show');
            }).fail(function () {
                Swal.fire("Error!", "Failed to load author details.", "error");
            });
        });

        $('.deleteAuthor').click(function (e) {
                e.preventDefault();
                        Swal.fire({
                  title: "Do you want to save the changes?",
                  showCancelButton: true,
                  confirmButtonText: "Save"
                }).then((result) => {
                  /* Read more about isConfirmed, isDenied below */
                  if (result.isConfirmed) 
                  {
                      //author/delete/id
                    var url = $(this).attr('href');
                    $.ajax({
                        url: url,
                        type: 'get',
                        success: function (response) {
                            if (response.success) {
                                Swal.fire("Deleted!", response.message, "success").then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire("Error!", response.message, "error");
                            }
                        },
                        error: function () {
                            Swal.fire("Error!", "An error occurred while processing your request.", "error");
                        }
                });
              }
                  else if (result.isDenied) Swal.fire("Changes are not saved", "", "info");
                });
            });
    </script>
}