@model PustokAppMvc.ViewModel.UserVm.LoginVm

<section class="breadcrumb-section">
	<h2 class="sr-only">Site Breadcrumb</h2>
	<div class="container">
		<div class="breadcrumb-contents">
			<nav aria-label="breadcrumb">
				<ol class="breadcrumb">
					<li class="breadcrumb-item"><a href="index.html">Home</a></li>
					<li class="breadcrumb-item active">Register</li>
				</ol>
			</nav>
		</div>
	</div>
</section>
<!--=============================================
=            Login Register page content         =
=============================================-->
<main class="page-section inner-page-sec-padding-bottom">
	<div class="container">
		<div class="row">
			<div class="col-sm-12 col-md-12 col-xs-12 col-lg-6 mb--30 mb-lg--0 text-center">
				<!-- Register Form -->
				<form asp-action="login" asp-controller="Account" method="post">
					<div class="login-form">
						<h4 class="login-title">New Customer</h4>
						<p><span class="font-weight-bold">I am a new customer</span></p>
						<div asp-validation-summary="ModelOnly" class="text-danger mb--15"></div>
						<div class="row">
							<div class="col-md-12 col-12 mb--15">
								<label asp-for="UserNameOrEmail">Username or Email</label>
								<input asp-for="UserNameOrEmail" class="mb-0 form-control" placeholder="Enter your username">
								<span asp-validation-for="UserNameOrEmail" class="text-danger"></span>
							</div>
							<div class="col-lg-6 mb--20">
								<label asp-for="Password">Password</label>
								<input asp-for="Password" class="mb-0 form-control" type="password" placeholder="Enter your password">
								<span asp-validation-for="Password" class="text-danger"></span>
							</div>
							<div class="">
								<label asp-for="RememberMe"></label>
								<input asp-for="RememberMe" class="mb-0" type="checkbox">
							</div>
							<div class="col-md-12">
								<button type="submit" class="btn btn-outlined">Login</button>
							</div>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
</main>

@section scripts {
	<partial name="_ValidationScriptsPartial" />
}